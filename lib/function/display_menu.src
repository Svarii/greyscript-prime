keepAlive = true
myMenu = ["item 1", "item2", "item3", "item4"]
menuSelection = 0

menu_select = function(menuSelection, myMenu)
    return user_navigation(menuSelection, user_input("", false, true)).clamp(0, (myMenu.len - 1))
end function

while not userInput ==  "LeftArrow"
    clear_screen
    menu = display_menu(myMenu, menuSelection)
    for line in menu
        print line
    end for
    menuSelection = menu_select(menuSelection, myMenu)
    //menuSelection = (user_navigation(menuSelection, user_input("", false, true))).clamp(0, (myMenu.len - 1))
end while 